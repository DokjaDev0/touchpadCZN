<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0F0F23">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#E94560"
        android:fontFamily="monospace"
        android:layout_marginBottom="2dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="dual display controller"
        android:textSize="12sp"
        android:textColor="#00AAFF"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <!-- Display info card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A0A1E"
        android:padding="12dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_displays"
            android:textSize="10sp"
            android:textColor="#4466AA"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_display_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="detecting..."
            android:textSize="12sp"
            android:textColor="#00CCFF"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Status card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A0A1E"
        android:padding="12dp"
        android:layout_marginBottom="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_status"
            android:textSize="10sp"
            android:textColor="#4466AA"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="starting..."
            android:textSize="13sp"
            android:textColor="#E94560"
            android:fontFamily="monospace" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_accessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_enable_accessibility"
        android:backgroundTint="#1A1A3A"
        android:textColor="#00AAFF"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_launch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_launch"
        android:backgroundTint="#E94560"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:enabled="false" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/instructions"
        android:textSize="11sp"
        android:textColor="#4466AA"
        android:fontFamily="monospace"
        android:layout_marginTop="18dp" />

</LinearLayout>
